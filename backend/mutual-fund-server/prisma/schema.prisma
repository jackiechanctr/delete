generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["mutual_fund"]
}

enum SipFrequency {
  MONTHLY
  QUARTERLY
  WEEKLY

  @@schema("mutual_fund")
}

enum SipStatus {
  ACTIVE
  PAUSED
  FAILED
  CANCELLED

  @@schema("mutual_fund")
}

enum MfTransactionType {
  PURCHASE
  REDEMPTION
  SIP
  DIVIDEND

  @@schema("mutual_fund")
}

model Fund {
  id          String   @id @default(uuid()) @db.Uuid
  schemeCode  String   @unique @map("scheme_code")
  name        String
  category    String
  amc         String
  riskLevel   String   @map("risk_level")
  createdAt   DateTime @default(now()) @map("created_at")

  navHistory   NavHistory[]
  sips         Sip[]
  transactions MfTransaction[]

  @@map("funds")
  @@schema("mutual_fund")
}

model NavHistory {
  id        String   @id @default(uuid()) @db.Uuid
  fundId    String   @map("fund_id") @db.Uuid
  nav       Decimal  @db.Decimal(18, 6)
  navDate   DateTime @map("nav_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([fundId, navDate])
  @@index([navDate])
  @@map("nav_history")
  @@schema("mutual_fund")
}

model Sip {
  id          String       @id @default(uuid()) @db.Uuid
  investorRef String       @map("investor_ref")
  fundId      String       @map("fund_id") @db.Uuid
  amount      Decimal      @db.Decimal(18, 2)
  frequency   SipFrequency
  status      SipStatus    @default(ACTIVE)
  startDate   DateTime     @map("start_date") @db.Date
  nextDueDate DateTime?    @map("next_due_date") @db.Date
  mandateId   String?      @map("mandate_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([investorRef])
  @@index([status])
  @@map("sips")
  @@schema("mutual_fund")
}

model MfTransaction {
  id          String            @id @default(uuid()) @db.Uuid
  investorRef String            @map("investor_ref")
  fundId      String            @map("fund_id") @db.Uuid
  type        MfTransactionType
  units       Decimal           @db.Decimal(18, 6)
  nav         Decimal           @db.Decimal(18, 6)
  amount      Decimal           @db.Decimal(18, 2)
  executedAt  DateTime          @map("executed_at")
  idempotencyKey String?        @unique @map("idempotency_key")
  createdAt   DateTime          @default(now()) @map("created_at")

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([investorRef, executedAt])
  @@map("transactions")
  @@schema("mutual_fund")
}

model ApiClient {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  apiKey    String   @unique @map("api_key")
  secretHash String  @map("secret_hash")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("api_clients")
  @@schema("mutual_fund")
}
